# Supabase public config (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma - Connection pooling for app queries (via pgBouncer at port 6543)
DATABASE_URL="postgresql://postgres.dhtnbwqtbyugozmwronx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma - Direct connection for migrations (at port 5432)
DIRECT_URL="postgresql://postgres.dhtnbwqtbyugozmwronx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-secure-random-string

# Quote approval automation webhook (triggered after employee approves a quote)
QUOTE_APPROVAL_WEBHOOK_URL=https://your-n8n-domain/webhook/quote-approval

# Optional: endpoint that your Zalo sender workflow or service listens to
ZALO_NOTIFICATION_WEBHOOK_URL=https://your-zalo-notification-endpoint.example/webhook
