    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n  const parsed = [];\n\n  for (const item of items) {\n    try {\n      let outputString = item.json.output || item.json;\n\n      if (typeof outputString === 'object' && outputString !== null) {\n        parsed.push({\n          ...outputString,\n          parseSuccess: true,\n          parsedAt: new Date().toISOString()\n        });\n        continue;\n      }\n\n      if (typeof outputString === 'string') {\n        let cleanString = outputString.trim();\n\n        if (cleanString.startsWith('```json')) {\n          cleanString = cleanString.replace(/^```json\\s*/, '').replace(/\\s*```$/, '');\n        } else if (cleanString.startsWith('```')) {\n          cleanString = cleanString.replace(/^```\\s*/, '').replace(/\\s*```$/, '');\n        }\n\n        const parsedData = JSON.parse(cleanString);\n        parsed.push({\n          ...parsedData,\n          parseSuccess: true,\n          parsedAt: new Date().toISOString()\n        });\n        continue;\n      }\n\n      parsed.push({\n        rawData: outputString,\n        parseSuccess: false,\n        error: 'Unsupported output type',\n        parsedAt: new Date().toISOString()\n      });\n    } catch (itemError) {\n      parsed.push({\n        rawData: item.json.output || item.json,\n        parseSuccess: false,\n        error: itemError.message,\n        parsedAt: new Date().toISOString()\n      });\n    }\n  }\n\n  return parsed.map(item => ({ json: item }));\n} catch (error) {\n  return [{\n    json: {\n      parseSuccess: false,\n      error: error.message,\n      parsedAt: new Date().toISOString()\n    }\n  }];\n}"
      },
