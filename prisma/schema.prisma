generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?          @map("password_hash")
  accounts        Account[]
  actionLogs      ActionLog[]
  customerSetting CustomerSetting?
  notifications   Notification[]
  orders          Order[]
  profile         Profile?
  quoteRequests   QuoteRequest[]
  sessions        Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String?  @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  company   String?  @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  role      String   @default("customer") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Order {
  id                   String          @id @default(cuid())
  userId               String          @map("user_id") @db.Uuid
  orderCode            String          @unique @map("order_code") @db.VarChar(50)
  origin               String          @db.VarChar(255)
  destination          String          @db.VarChar(255)
  serviceType          String          @map("service_type") @db.VarChar(50)
  status               String          @default("pending") @db.VarChar(30)
  currentLocation      String?         @map("current_location") @db.VarChar(255)
  weightKg             Int?            @map("weight_kg")
  totalAmount          Int?            @map("total_amount")
  estimatedDelivery    DateTime?       @map("estimated_delivery") @db.Timestamptz(6)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedDriverId     String?         @map("assigned_driver_id") @db.Uuid
  assignedVehicleId    String?         @map("assigned_vehicle_id") @db.Uuid
  assigned_driver_name String?
  plate_number         String?         @db.VarChar
  notifications        Notification[]
  assignedDriver       Driver?         @relation(fields: [assignedDriverId], references: [id])
  assignedVehicle      Vehicle?        @relation(fields: [assignedVehicleId], references: [id])
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  slaAlerts            SlaAlert[]
  trackingEvents       TrackingEvent[]

  @@index([userId, status])
  @@map("orders")
}

model QuoteRequest {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id") @db.Uuid
  quoteCode           String   @unique @map("quote_code") @db.VarChar(50)
  serviceType         String   @map("service_type") @db.VarChar(50)
  origin              String   @db.VarChar(255)
  destination         String   @db.VarChar(255)
  weight              String?  @db.VarChar(50)
  dimensions          String?  @db.VarChar(100)
  note                String?
  status              String   @default("pending") @db.VarChar(30)
  quotedPrice         Int?     @map("quoted_price")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  customerName        String?  @map("customer_name") @db.VarChar(255)
  customerPhone       String?  @map("customer_phone") @db.VarChar(50)
  customerEmail       String?  @map("customer_email") @db.VarChar(255)
  suggestedSurcharges Json?    @map("suggested_surcharges")
  finalSuggestedPrice Int?     @map("final_suggested_price")
  pricingReasoning    String?  @map("pricing_reasoning")
  priceBase           Int?     @map("Price_Base")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("quote_requests")
}

model TrackingEvent {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  status      String   @db.VarChar(30)
  location    String   @db.VarChar(255)
  description String
  eventTime   DateTime @default(now()) @map("event_time") @db.Timestamptz(6)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, eventTime(sort: Desc)])
  @@map("tracking_events")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id") @db.Uuid
  type      String    @default("info") @db.VarChar(20)
  title     String    @db.VarChar(255)
  message   String
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  channel   String?   @default("in_app") @db.VarChar(50)
  orderId   String?   @map("order_id")
  sentAt    DateTime? @default(now()) @map("sent_at") @db.Timestamptz(6)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model CustomerSetting {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id") @db.Uuid
  language           String   @default("vi") @db.VarChar(10)
  theme              String   @default("light") @db.VarChar(20)
  emailNotifications Boolean  @default(true) @map("email_notifications")
  smsNotifications   Boolean  @default(false) @map("sms_notifications")
  pushNotifications  Boolean  @default(true) @map("push_notifications")
  companyName        String?  @map("company_name") @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  address            String?  @db.VarChar(255)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_settings")
}

model ActionLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id") @db.Uuid
  mode       String   @default("manual") @db.VarChar(20)
  actionType String   @map("action_type") @db.VarChar(80)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(120)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([mode, createdAt])
  @@index([actionType, createdAt])
  @@index([actorId, createdAt])
  @@map("action_logs")
}

model SlaAlert {
  id         String   @id @default(cuid())
  orderId    String?  @map("order_id")
  type       String   @default("alert") @db.VarChar(30)
  status     String   @default("open") @db.VarChar(30)
  severity   String?  @db.VarChar(20)
  message    String?
  metadata   Json?
  detectedAt DateTime @map("detected_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("sla_alerts")
}

model DailyKpiReport {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  generatedAt  DateTime @map("generated_at") @db.Timestamptz(6)
  reportType   String?  @map("report_type")
  summary      Json?
  operations   Json?
  financial    Json?
  totalRevenue BigInt?  @map("total_revenue")
  onTimeRate   Float?   @map("on_time_rate")
  slaAlerts    Int?     @map("sla_alerts")
  rawData      Json?    @map("raw_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([generatedAt])
  @@index([reportType, generatedAt])
  @@map("daily_kpi_reports")
}

model Intervention {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String
  actionType String   @db.VarChar(50)
  reason     String
  status     String   @db.VarChar(50)
  notifiedAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("interventions")
}

model Driver {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  region    String?
  status    String   @default("available")
  workload  Int      @default(0)
  licenses  String?  @default("")
  vehicleId String?  @map("vehicle_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  email     String?  @db.VarChar
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  orders    Order[]

  @@map("drivers")
}

model Vehicle {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleType              String   @map("vehicle_type")
  capacityKg               Int?     @map("capacity_kg")
  status                   String   @default("available")
  region                   String?
  plateNumber              String?  @map("plate_number")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  capacity_available       Int?
  capacity_current_percent Float?
  drivers                  Driver[]
  orders                   Order[]

  @@map("vehicles")
}
